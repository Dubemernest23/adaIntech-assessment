generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum NotificationChannel {
  email
  sms
  in_app
}

enum NotificationCategory {
  compliance
  billing
  engagement
  system
}

enum DeliveryMode {
  realtime
  daily_digest
}

enum ProductLine {
  saas
  fintech
  ple
}

enum DeliveryStatus {
  sent
  failed
  queued
  skipped
}

enum EventType {
  transaction_created @map("transaction.created")
  invoice_due         @map("invoice.due")
  user_onboarded      @map("user.onboarded")
  compliance_flagged  @map("compliance.flagged")
  system_alert        @map("system.alert")
}

model NotificationPreference {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  tenantId        String   @map("tenant_id")
  emailEnabled    Boolean  @default(true) @map("email_enabled")
  smsEnabled      Boolean  @default(false) @map("sms_enabled")
  inAppEnabled    Boolean  @default(true) @map("in_app_enabled")
  quietHoursStart String?  @map("quiet_hours_start")
  quietHoursEnd   String?  @map("quiet_hours_end")
  timezone        String   @default("UTC")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  categories NotificationCategoryPreference[]

  @@unique([userId, tenantId])
  @@index([tenantId])
  @@index([userId, tenantId])
  @@map("notification_preferences")
}

model NotificationCategoryPreference {
  id           String               @id @default(uuid())
  preferenceId String               @map("preference_id")
  tenantId     String               @map("tenant_id")
  category     NotificationCategory
  enabled      Boolean              @default(true)
  deliveryMode DeliveryMode         @default(realtime) @map("delivery_mode")
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")

  preference NotificationPreference @relation(fields: [preferenceId], references: [id], onDelete: Cascade)

  @@unique([preferenceId, category])
  @@index([tenantId])
  @@index([preferenceId, tenantId])
  @@map("notification_category_preferences")
}

model IncomingEvent {
  id            String    @id @default(uuid())
  eventId       String    @unique @map("event_id")
  eventType     EventType @map("event_type")
  tenantId      String    @map("tenant_id")
  userId        String?   @map("user_id")
  productLine   ProductLine @map("product_line")
  schemaVersion String    @map("schema_version")
  payload       Json
  occurredAt    DateTime  @map("occurred_at")
  receivedAt    DateTime  @default(now()) @map("received_at")
  processed     Boolean   @default(false)

  deliveryRecords DeliveryRecord[]

  @@index([eventId])
  @@index([tenantId])
  @@index([userId, tenantId])
  @@map("incoming_events")
}

model DeliveryRecord {
  id            String         @id @default(uuid())
  eventId       String         @map("event_id")
  userId        String
  tenantId      String         @map("tenant_id")
  channel       String
  status        DeliveryStatus
  skipReason    String?        @map("skip_reason")
  attemptedAt   DateTime       @default(now()) @map("attempted_at")
  correlationId String         @map("correlation_id")

  event IncomingEvent @relation(fields: [eventId], references: [eventId], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId, tenantId])
  @@index([eventId])
  @@map("delivery_records")
}